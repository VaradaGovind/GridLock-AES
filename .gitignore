#-----------------------------------
# GridLock AES: Vivado + SystemVerilog (Safe Version)
# Keeps RTL, Testbench, Constraints, and Project files
#-----------------------------------

# Ignore Vivado-generated folders
.Xil/
*.cache/
*.hw/
*.ip_user_files/
*.runs/
*.sim/
*.data/
*.xsa/
*.dcp/
*.ip/
*.xci/
*.backup.log
*.backup.jou

# Simulation and Synthesis outputs
*.vcd
*.wlf
*.log
*.jou
*.pb
*.rpt
*.saif
*.wdb
xsim.dir/

# Temporary/editor files
*~
*.swp
*.tmp
*.bak
.DS_Store
.DS_Store?
.vscode/
.idea/

#-----------------------------------
# KEEP explicitly (Whitelist)
#-----------------------------------

# Hardware Source & Testbench files
!*.v
!*.vh
!*.sv
!*.svh

# Vivado Constraints (Clock & Pin mapping)
!*.xdc

# Vivado Project File (Required to open the project)
!*.xpr

# Keep images and documentation
!*.png
!*.jpg
!*.jpeg
!*.md

# Keep repository structure files
!.gitignore
!README.md
